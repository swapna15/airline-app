{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["shared/**/*", "authorizer/**/*", "users/**/*", "flights/**/*", "bookings/**/*", "checkin/**/*", "gate/**/*", "admin/**/*"],
  "exclude": ["node_modules", "dist"]
}
